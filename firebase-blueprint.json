{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "Customer inquiry for wholesale bags",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the customer"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the customer"
        },
        "businessName": {
          "type": "string",
          "description": "Name of the customer's business"
        },
        "city": {
          "type": "string",
          "description": "City or State of the customer"
        },
        "requirement": {
          "type": "string",
          "description": "Estimated monthly requirement"
        },
        "message": {
          "type": "string",
          "description": "Inquiry message or requirements"
        },
        "categories": {
          "type": "array",
          "description": "List of interested product categories"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the inquiry was created"
        },
        "status": {
          "type": "string",
          "enum": ["new", "contacted", "closed"],
          "description": "Current status of the inquiry"
        }
      },
      "required": ["name", "phone", "message", "createdAt", "status"]
    },
    "Contact": {
      "title": "Contact",
      "description": "General contact form submission",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the person"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        },
        "phone": {
          "type": "string",
          "description": "Phone number"
        },
        "subject": {
          "type": "string",
          "description": "Subject of the message"
        },
        "message": {
          "type": "string",
          "description": "Message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the contact was created"
        },
        "status": {
          "type": "string",
          "enum": ["new", "read", "replied"],
          "description": "Current status of the contact message"
        }
      },
      "required": ["name", "phone", "message", "createdAt", "status"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of customer inquiries"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Collection of general contact messages"
    }
  }
}
